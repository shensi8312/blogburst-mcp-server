                  "enum": [
                    "twitter",
                    "linkedin",
                    "reddit",
                    "bluesky",
                    "threads",
                    "telegram",
                    "discord",
                    "tiktok",
                    "youtube"
                  ]
                },
                "description": "Platforms to auto-post to"
              },
              "timezone": {
                "type": "string",
                "description": "Timezone for scheduling posts (e.g. \"America/New_York\", \"Asia/Shanghai\")"
              }
